---
// Visionneuse d'images. La logique est dans src/scripts/lightbox.ts.
// Se place une fois par page contenant des cartes de réalisation.
---

<div
  data-lightbox
  class="pointer-events-none fixed inset-0 z-[100] flex items-center justify-center opacity-0 transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
  aria-label="Visionneuse de réalisations"
  aria-hidden="true"
>
  <div data-lightbox-backdrop class="absolute inset-0 bg-black/90 backdrop-blur-sm"></div>

  <!-- Fermer -->
  <button
    type="button"
    data-lightbox-close
    aria-label="Fermer la visionneuse"
    class="absolute right-4 top-4 z-10 flex h-12 w-12 cursor-pointer items-center justify-center rounded-full border border-slate/40 text-white transition-colors duration-200 hover:border-orange hover:text-orange md:right-6 md:top-6"
  >
    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
    </svg>
  </button>

  <!-- Précédent -->
  <button
    type="button"
    data-lightbox-prev
    aria-label="Image précédente"
    class="absolute left-2 z-10 flex h-12 w-12 cursor-pointer items-center justify-center rounded-full border border-slate/40 text-white transition-colors duration-200 hover:border-orange hover:text-orange md:left-6"
  >
    <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M15 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>

  <!-- Suivant -->
  <button
    type="button"
    data-lightbox-next
    aria-label="Image suivante"
    class="absolute right-2 z-10 flex h-12 w-12 cursor-pointer items-center justify-center rounded-full border border-slate/40 text-white transition-colors duration-200 hover:border-orange hover:text-orange md:right-6"
  >
    <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>

  <!-- Contenu -->
  <figure data-lightbox-content class="relative z-[1] flex flex-col items-center px-16">
    <img
      data-lightbox-image
      alt=""
      class="hidden max-h-[80svh] w-auto max-w-full rounded-sm object-contain"
    />
    <div
      data-lightbox-placeholder
      class="hidden aspect-[4/3] w-[80vw] max-w-3xl items-center justify-center rounded-sm bg-charcoal"
      role="img"
    >
      <span data-lightbox-placeholder-label class="px-6 text-center text-sm text-slate"></span>
    </div>
    <figcaption data-lightbox-caption class="mt-4 text-center font-display text-sm text-white/80"></figcaption>
  </figure>
</div>

<script>
  import '../scripts/lightbox';
</script>
