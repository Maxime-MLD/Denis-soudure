---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import coffret from '../assets/images/coffret.png';
import fenetre from '../assets/images/fenetre.png';
import porte from '../assets/images/porte.png';
import face from '../assets/images/face.png';

interface Block {
  kicker: string;
  title: string;
  text: string;
  image: ImageMetadata | null;
  alt: string;
  imageRight: boolean;
}

const blocks: Block[] = [
  {
    kicker: '100% Sur-mesure',
    title: 'Votre projet, conçu exactement comme vous l\'imaginez',
    text: `Ici, chaque réalisation est pensée sur-mesure pour s'adapter parfaitement à vos besoins. Qu'il s'agisse de mes créations habituelles ou d'un projet spécifique, tout est modulable. Vous avez une idée en tête ? j'ajoute les options, rangements et finitions de votre choix pour créer une pièce unique, faite pour vous.`,
    image: coffret,
    alt: 'Coffre de rangement métallique sur-mesure fabriqué par DeniSoudure à Roanne',
    imageRight: true,
  },
  {
    kicker: 'Matériaux de qualité',
    title: "La robustesse avant tout",
    text: `Parce qu'une création sur-mesure doit traverser le temps, je ne fais aucun compromis sur la matière première. Je sélectionne des métaux de haute qualité, choisis pour leur résistance, leur durabilité et leurs finitions impeccables. Que ce soit pour un usage intérieur ou extérieur, chaque matériau est rigoureusement travaillé pour garantir une structure aussi solide qu'esthétique.`,
    image: fenetre,
    alt: 'Fenêtre métallique sur-mesure en acier réalisée par DeniSoudure à Roanne',
    imageRight: false,
  },
  {
    kicker: 'Fabrication artisanale',
    title: "Tout est réalisé dans mon atelier",
    text: `Pour garantir une qualité irréprochable, je réalise l'intégralité de mon travail dans mon atelier. De la découpe précise du métal au pliage et à l'assemblage, chaque étape est effectuée par mes soins. En maîtrisant l'ensemble de la chaîne de fabrication, je vous assure un suivi rigoureux et une finition soignée sur chaque pièce qui sort de mon atelier.`,
    image: porte,
    alt: 'Porte métallique sur-mesure fabriquée par DeniSoudure à Roanne',
    imageRight: true,
  },
  {
    kicker: 'Robustesse & Durabilité',
    title: 'Conçu pour durer, fabriqué pour résister',
    text: `Mon objectif est simple : créer des structures qui ne bougent pas. En alliant des matériaux de premier choix à une technique de soudure rigoureuse, je conçois des pièces capables d'affronter le quotidien, les intempéries ou les usages intensifs. Choisir mon travail, c'est investir dans une réalisation durable qui allie solidité technique et finitions irréprochables pour vous offrir une tranquillité totale sur le long terme.`,
    image: face,
    alt: 'Caisse à chien sur-mesure terminée, réalisée par DeniSoudure à Roanne',
    imageRight: false,
  },
];
---

<section id="a-propos" class="container-site section-space">
  {/* Conteneur commun (max-width 1700px centré à partir de lg) : le H2 et les blocs
      partagent cette largeur, donc le titre est aligné avec les blocs. */}
  <div class="lg:mx-auto lg:max-w-[1700px]">
    <h2 data-anim="up" class="max-w-2xl text-3xl md:text-5xl ">
      Le savoir-faire d'un artisan, au service de votre projet
    </h2>

    <div class="mt-16 flex flex-col gap-20 md:mt-24 md:gap-28">
      {
        blocks.map((block) => (
          <article class="grid items-center gap-8 lg:grid-cols-2 lg:gap-16">
            {/* Sous lg : colonne unique, image au-dessus du texte + liseré horizontal ;
                à partir de lg : liseré vertical toujours à gauche du texte. */}
            <div
              data-anim={block.imageRight ? 'left' : 'right'}
              class:list={[
                'order-2 max-w-lg border-orange border-t-[3px] pt-6 lg:border-t-0 lg:border-l-[3px] lg:pt-0 lg:pl-8',
                block.imageRight ? 'lg:order-1' : 'lg:order-2',
              ]}
            >
            <p class="text-sm font-semibold uppercase tracking-widest text-orange">{block.kicker}</p>
            <h3 class="mt-3 text-2xl font-semibold md:text-3xl">{block.title}</h3>
            <p class="mt-5 leading-relaxed text-slate">{block.text}</p>
          </div>
          <div
            data-anim={block.imageRight ? 'right' : 'left'}
            class:list={['order-1', block.imageRight ? 'lg:order-2' : 'lg:order-1']}
          >
            {block.image ? (
              <Image
                src={block.image}
                alt={block.alt}
                widths={[400, 800, 1200]}
                sizes="(min-width: 1024px) 40vw, 90vw"
                format="webp"
                class="aspect-[4/3] w-full rounded-sm object-cover"
              />
            ) : (

              <div
                class="flex aspect-[4/3] items-center justify-center rounded-sm bg-charcoal"
                role="img"
                aria-label={block.alt}
              >
              </div>
            )}
          </div>
        </article>
      ))
    }
    </div>
  </div>
</section>
