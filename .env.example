# Copier ce fichier vers .env et renseigner les valeurs réelles.

# --- Web3Forms (formulaire de contact) ---
# Clé publique par conception (Web3Forms est appelé côté client).
PUBLIC_WEB3FORMS_KEY=YOUR_WEB3FORMS_ACCESS_KEY

# --- Sanity (gestion des réalisations par le client) ---
# projectId & dataset ne sont pas secrets (identifiants publics).
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
# Optionnel : uniquement si le dataset est privé. Jeton de rôle "Viewer".
# NE PAS préfixer par PUBLIC_ (reste côté serveur, au build).
# SANITY_API_READ_TOKEN=
# Uniquement pour l'import en masse (scripts/import-realisations.mjs).
# Jeton rôle "Editor" — sanity.io/manage → API → Tokens. Ne jamais commiter.
# SANITY_API_WRITE_TOKEN=
